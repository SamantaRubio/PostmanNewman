		{
			"name": "Products",
			"item": [
				{
					"name": "GET all products",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"const products = pm.response.json();",
									"",
									"pm.test(\"Response is a non-empty array\", function () {",
									"    pm.expect(products).to.be.an('array').that.is.not.empty;",
									"});",
									"",
									"pm.test(\"Each product matches the product JSON schema\", function () {",
									"    const Ajv = require('ajv');",
									"    const ajv = new Ajv({ allErrors: true });",
									"    const productSchema = {",
									"        type: 'object',",
									"        required: ['id', 'title', 'price', 'description', 'category', 'image'],",
									"        properties: {",
									"            id: { type: 'integer' },",
									"            title: { type: 'string' },",
									"            price: { type: 'number' },",
									"            description: { type: 'string' },",
									"            category: { type: 'string' },",
									"            image: { type: 'string' },",
									"            rating: {",
									"                type: 'object',",
									"                properties: {",
									"                    rate: { type: 'number' },",
									"                    count: { type: 'integer' }",
									"                }",
									"            }",
									"        }",
									"    };",
									"    const validate = ajv.compile(productSchema);",
									"    products.forEach(function (p) {",
									"        const valid = validate(p);",
									"        pm.expect(valid, JSON.stringify(validate.errors)).to.be.true;",
									"    });",
									"});",
									"",
									"// Save a real id for later GET-by-id test",
									"pm.collectionVariables.set('sampleProductId', products[0].id);"
								]
